INSERT INTO inspectors (control_id, teacher_id, first_name, last_name, patronymic, external)
SELECT
    c.id,
    t.user_id,
    u.first_name,
    u.last_name,
    u.patronymic,
    false
FROM controls c
CROSS JOIN teachers t
JOIN users u ON t.user_id = u.id
WHERE c.group_id = (SELECT id FROM groups WHERE number = '220302')
  AND c.date = '2026-02-21'
  AND u.university_id = 2;


DO $$
DECLARE
    v_control_id bigint;
    v_standard_100m bigint;
    v_standard_pullup bigint;
    v_standard_3km bigint;
    v_cadet record;
    v_mark1 smallint;
    v_mark2 smallint;
    v_mark3 smallint;
BEGIN
    SELECT id INTO v_control_id
    FROM controls
    WHERE group_id = (SELECT id FROM groups WHERE number = '220302')
      AND date = '2026-02-21'
    ORDER BY id DESC LIMIT 1;

    SELECT id INTO v_standard_100m FROM standards WHERE number = 12 LIMIT 1;
    SELECT id INTO v_standard_pullup FROM standards WHERE number = 28 LIMIT 1;
    SELECT id INTO v_standard_3km FROM standards WHERE number = 18 LIMIT 1;

    FOR v_cadet IN
        SELECT
            c.user_id,
            c.course,
            c.military_rank,
            c.post,
            u.last_name,
            u.first_name
        FROM cadets c
        JOIN users u ON c.user_id = u.id
        WHERE c.group_id = (SELECT id FROM groups WHERE number = '220302')
        ORDER BY u.last_name
    LOOP

        IF v_cadet.user_id = 1 THEN
            v_mark1 := 5;
            v_mark2 := 5;
            v_mark3 := 5;


        ELSIF v_cadet.user_id = 2 THEN
            v_mark1 := 5;
            v_mark2 := 5;
            v_mark3 := 4;


        ELSIF v_cadet.user_id = 3 THEN
            v_mark1 := 3;
            v_mark2 := 3;
            v_mark3 := 3;


        ELSIF v_cadet.user_id = 4 THEN
            v_mark1 := 4;
            v_mark2 := 4;
            v_mark3 := 3;


        ELSIF v_cadet.user_id = 5 THEN
            v_mark1 := 3;
            v_mark2 := 3;
            v_mark3 := 2;


        ELSIF v_cadet.user_id = 6 THEN
            v_mark1 := 4;
            v_mark2 := 4;
            v_mark3 := 4;


        ELSIF v_cadet.user_id = 7 THEN
            v_mark1 := 5;
            v_mark2 := 4;
            v_mark3 := 4;


        ELSIF v_cadet.user_id = 8 THEN
            v_mark1 := 4;
            v_mark2 := 4;
            v_mark3 := 2;

        ELSIF v_cadet.user_id = 9 THEN
            v_mark1 := 4;
            v_mark2 := 3;
            v_mark3 := 3;


        ELSE

            v_mark1 := 3 + (v_cadet.user_id % 3); -- 3,4,5
            v_mark2 := 3 + ((v_cadet.user_id + 1) % 3);
            v_mark3 := 3 + ((v_cadet.user_id + 2) % 3);
        END IF;


        INSERT INTO control_results (control_id, cadet_id, status, standard_id, mark) VALUES
        (v_control_id, v_cadet.user_id, 'Присутствует', v_standard_100m, v_mark1),
        (v_control_id, v_cadet.user_id, 'Присутствует', v_standard_pullup, v_mark2),
        (v_control_id, v_cadet.user_id, 'Присутствует', v_standard_3km, v_mark3);


        INSERT INTO control_summaries (control_id, cadet_id, cadet_military_rank, cadet_post, final_mark)
        VALUES (v_control_id, v_cadet.user_id, v_cadet.military_rank, v_cadet.post, NULL);

    END LOOP;
END $$;


UPDATE control_summaries
