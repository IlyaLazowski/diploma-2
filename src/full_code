                if (intValue != null) {
                    log.trace("Сравнение с нормативом Удовлетворительно: стандарт={}, результат={}",
                            intValue.intValue(), result);
                    if (result >= intValue.intValue()) {
                        log.debug("Результат соответствует оценке 3 (Удовлетворительно)");
                        return 3;
